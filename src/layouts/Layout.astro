---
interface Props {
  title: string;
  description?: string;
  canonical?: string;
  noindex?: boolean;
}
const { title, description = "Ostéopathe animalier et technicien dentaire équin, Sophie Pouget-Leroy partage ses réflexions sur la pratique, le corps et la transmission.", canonical, noindex = false } = Astro.props;
const currentPath = Astro.url.pathname;
---

<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{title}</title>
  <meta name="description" content={description}>
  <meta name="author" content="Sophie Pouget-Leroy">
  {noindex ? <meta name="robots" content="noindex"> : <meta name="robots" content="index, follow">}
  {canonical && <link rel="canonical" href={canonical}>}
  <meta property="og:title" content={title}>
  <meta property="og:description" content={description}>
  <meta property="og:type" content="website">
  <meta property="og:locale" content="fr_FR">
  {canonical && <meta property="og:url" content={canonical}>}
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;1,300;1,400&family=Jost:wght@300;400&display=swap" rel="stylesheet">
  <style is:global>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { background: #f2ede8; font-family: 'Jost', sans-serif; color: #3a3835; }
    .line { border: none; border-top: 0.5px solid #b8b3ac; }

    /* NAV */
    nav { background: #f2ede8; padding: 20px 56px; display: flex; justify-content: space-between; align-items: center; position: sticky; top: 0; z-index: 10; }
    .nav-name { font-family: 'Cormorant Garamond', serif; font-weight: 300; font-size: 19px; letter-spacing: 0.03em; text-decoration: none; color: #3a3835; }
    .nav-links { display: flex; gap: 36px; font-size: 10px; letter-spacing: 0.18em; text-transform: uppercase; color: #6b6760; }
    .nav-link { text-decoration: none; color: #6b6760; padding-bottom: 2px; border-bottom: 0.5px solid transparent; transition: all 0.2s; }
    .nav-link:hover { color: #3a3835; border-bottom-color: #3a3835; }
    .nav-link.active { color: #3a3835; border-bottom-color: #3a3835; }
    .nav-toggle { display: none; cursor: pointer; flex-direction: column; gap: 5px; background: none; border: none; padding: 0; }
    .nav-toggle span { display: block; width: 22px; height: 1px; background: #3a3835; }

    /* HERO */
    .hero { display: grid; grid-template-columns: 1fr 1fr; height: 380px; }
    .hero-text { background: #f2ede8; padding: 48px 56px; display: flex; flex-direction: column; justify-content: center; }
    .hero-title { font-family: 'Cormorant Garamond', serif; font-weight: 300; font-size: 56px; line-height: 1.05; color: #3a3835; }
    .hero-meta { font-size: 10px; letter-spacing: 0.2em; text-transform: uppercase; color: #a09a93; margin-top: 24px; }
    .hero-photo { background: #c4b5a5; overflow: hidden; height: 380px; }

    /* RUBRIQUES */
    .rubriques { display: grid; grid-template-columns: 1fr 1fr 1fr; }
    .rubrique { padding: 32px 56px 40px; border-right: 0.5px solid #b8b3ac; transition: filter 0.15s; text-decoration: none; display: block; }
    .rubrique:last-child { border-right: none; }
    .rubrique:hover { filter: brightness(0.96); }
    .rub-penser { background: #e0cfc6; }
    .rub-toucher { background: #ccd4c2; }
    .rub-resonances { background: #d8d0c4; }
    .rub-bar { height: 2px; width: 28px; margin-bottom: 22px; }
    .rub-penser .rub-bar { background: #b89a8c; }
    .rub-toucher .rub-bar { background: #8a9e84; }
    .rub-resonances .rub-bar { background: #a09480; }
    .rub-num { font-size: 10px; letter-spacing: 0.2em; color: #8a847d; margin-bottom: 10px; }
    .rub-title { font-family: 'Cormorant Garamond', serif; font-size: 34px; font-weight: 300; color: #3a3835; margin-bottom: 10px; }
    .rub-desc { font-size: 12px; color: #5a5653; line-height: 1.75; }

    /* ARTICLES */
    .articles-zone { background: #ffffff; padding: 52px 56px; }
    .section-label { font-size: 10px; letter-spacing: 0.2em; text-transform: uppercase; color: #a09a93; margin-bottom: 36px; }
    .article-card { display: grid; grid-template-columns: 130px 1fr; gap: 32px; padding: 28px 0; border-top: 0.5px solid #e4dfd8; align-items: start; text-decoration: none; color: inherit; }
    .article-card:hover .art-title { color: #5a5653; }
    .article-img { height: 88px; border-radius: 2px; display: flex; align-items: center; justify-content: center; overflow: hidden; }
    .img-penser { background: #e0cfc6; }
    .img-toucher { background: #ccd4c2; }
    .img-resonances { background: #d8d0c4; }
    .art-rub { font-size: 10px; letter-spacing: 0.15em; text-transform: uppercase; color: #a09a93; margin-bottom: 8px; }
    .art-title { font-family: 'Cormorant Garamond', serif; font-size: 26px; font-weight: 300; color: #3a3835; margin-bottom: 10px; line-height: 1.2; transition: color 0.2s; }
    .art-excerpt { font-size: 13px; color: #6b6760; line-height: 1.8; }

    /* ARTICLE PAGE */
    .article-header { background: #f2ede8; padding: 64px 56px 48px; }
    .article-header-rub { font-size: 10px; letter-spacing: 0.2em; text-transform: uppercase; color: #a09a93; margin-bottom: 20px; }
    .article-header-title { font-family: 'Cormorant Garamond', serif; font-weight: 300; font-size: 52px; line-height: 1.1; color: #3a3835; margin-bottom: 20px; }
    .article-header-date { font-size: 11px; color: #a09a93; letter-spacing: 0.08em; }
    .article-body { background: #ffffff; padding: 64px 0; }
    .article-body-inner { max-width: 680px; margin: 0 auto; padding: 0 56px; }
    .article-body p { font-size: 17px; color: #3a3835; line-height: 2.1; margin-bottom: 32px; font-family: 'Cormorant Garamond', serif; font-weight: 300; }
    .article-body p:last-child { margin-bottom: 0; }
    .article-back { background: #f2ede8; padding: 28px 56px; }
    .article-back a { font-size: 10px; letter-spacing: 0.18em; text-transform: uppercase; color: #8a847d; text-decoration: none; border-bottom: 0.5px solid transparent; transition: all 0.2s; }
    .article-back a:hover { color: #3a3835; border-bottom-color: #3a3835; }

    /* À PROPOS */
    .apropos-hero { display: grid; grid-template-columns: 1fr 1fr; height: 380px; overflow: hidden; }
    .apropos-photo { background: #c4b5a5; overflow: hidden; }
    .apropos-intro { background: #f2ede8; padding: 64px 56px; display: flex; flex-direction: column; justify-content: center; }
    .apropos-intro h1 { font-family: 'Cormorant Garamond', serif; font-weight: 300; font-size: 54px; line-height: 1.05; margin-bottom: 24px; color: #3a3835; }
    .apropos-intro p { font-size: 11px; color: #6b6760; line-height: 2.2; letter-spacing: 0.04em; }
    .apropos-text { background: #ffffff; padding: 72px 0; }
    .apropos-text-inner { max-width: 680px; margin: 0 auto; padding: 0 56px; }
    .apropos-text p { font-size: 17px; color: #3a3835; line-height: 2.1; margin-bottom: 36px; font-family: 'Cormorant Garamond', serif; font-weight: 300; }
    .apropos-text p:last-child { margin-bottom: 0; }
    .apropos-credits { background: #f2ede8; padding: 48px 56px; display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 48px; }
    .credit-label { font-size: 10px; letter-spacing: 0.18em; text-transform: uppercase; color: #a09a93; margin-bottom: 16px; }
    .credit-item { font-size: 12px; color: #5a5653; line-height: 2.1; }

    /* FOOTER */
    footer { background: #f2ede8; padding: 20px 56px; display: flex; justify-content: space-between; align-items: center; gap: 24px; flex-wrap: wrap; }
    .footer-item { display: flex; align-items: center; gap: 6px; font-family: 'Jost', sans-serif; font-weight: 300; font-size: 10px; letter-spacing: 0.15em; color: #6b6760; text-decoration: none; transition: color 0.2s; white-space: nowrap; }
    .footer-item:hover { color: #3a3835; }
    .footer-item svg { flex-shrink: 0; }
    .footer-left { display: flex; gap: 24px; align-items: center; }
    .footer-right { display: flex; gap: 24px; align-items: center; }

    /* BACK TO TOP */
    #back-to-top { display: none; position: fixed; bottom: 32px; right: 32px; width: 40px; height: 40px; background: #f2ede8; border: 0.5px solid #b8b3ac; cursor: pointer; font-size: 16px; color: #6b6760; z-index: 100; transition: opacity 0.2s; }

    /* MOBILE */
    @media (max-width: 768px) {
      nav { padding: 16px 24px; position: relative; }
      .nav-links { display: none; flex-direction: column; gap: 20px; position: absolute; top: 100%; left: 0; right: 0; background: #f2ede8; padding: 24px; border-top: 0.5px solid #b8b3ac; z-index: 20; }
      .nav-links.open { display: flex; }
      .nav-toggle { display: flex; }
      .hero { grid-template-columns: 1fr; }
      .hero-text { padding: 48px 24px 40px; }
      .hero-title { font-size: 44px; }
      .hero-photo { min-height: 180px; height: auto; }
      .rubriques { grid-template-columns: 1fr; }
      .rubrique { padding: 28px 24px; border-right: none; border-bottom: 0.5px solid #b8b3ac; }
      .rubrique:last-child { border-bottom: none; }
      .articles-zone { padding: 36px 24px; }
      .article-card { grid-template-columns: 80px 1fr; gap: 16px; padding: 20px 0; }
      .article-img { height: 64px; }
      .art-title { font-size: 20px; }
      .article-header { padding: 40px 24px 32px; }
      .article-header-title { font-size: 34px; }
      .article-body-inner { padding: 0 24px; }
      .article-body p { font-size: 15px; }
      .article-back { padding: 20px 24px; }
      .apropos-hero { grid-template-columns: 1fr; height: auto; }
      .apropos-photo { min-height: 240px; }
      .apropos-intro { padding: 40px 24px; }
      .apropos-intro h1 { font-size: 38px; }
      .apropos-text-inner { padding: 0 24px; }
      .apropos-text p { font-size: 15px; }
      .apropos-credits { grid-template-columns: 1fr; gap: 32px; padding: 36px 24px; }
      footer { padding: 20px 24px; flex-direction: column; gap: 8px; text-align: center; }
    }
  </style>
</head>
<body>
  <hr class="line">
  <nav>
    <a href="/" class="nav-name">Sophie Pouget-Leroy</a>
    <button class="nav-toggle" id="nav-toggle" aria-label="Menu">
      <span></span><span></span><span></span>
    </button>
    <div class="nav-links" id="nav-menu">
      <a href="/" class:list={["nav-link", { active: currentPath === "/" }]}>Accueil</a>
      <a href="/penser" class:list={["nav-link", { active: currentPath.startsWith("/penser") }]}>Penser</a>
      <a href="/toucher" class:list={["nav-link", { active: currentPath.startsWith("/toucher") }]}>Toucher</a>
      <a href="/resonances" class:list={["nav-link", { active: currentPath.startsWith("/resonances") }]}>Résonances</a>
      <a href="/apropos" class:list={["nav-link", { active: currentPath === "/apropos" }]}>À propos</a>
      <a href="/contact" class:list={["nav-link", { active: currentPath === "/contact" }]}>Contact</a>
    </div>
  </nav>
  <hr class="line">

  <slot />

  <hr class="line">
  <footer>
    <div class="footer-left">
      <span class="footer-item">Ostéopathe animalier · Formatrice</span>
    </div>
    <div class="footer-right">
      <a href="https://www.linkedin.com/in/sophie-pouget-leroy-59b06823a" target="_blank" rel="noopener" class="footer-item">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect x="2" y="9" width="4" height="12"/><circle cx="4" cy="4" r="2"/></svg>
        LinkedIn
      </a>
      <a href="/mentions-legales" class="footer-item">Mentions légales</a>
      <span class="footer-item">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
        pouget-leroy.fr
      </span>
    </div>
  </footer>
  <hr class="line">

  <button id="back-to-top" onclick="window.scrollTo({top:0,behavior:'smooth'})" title="Haut de page">↑</button>

  <script>
    window.addEventListener('scroll', function() {
      const btn = document.getElementById('back-to-top');
      if (btn) btn.style.display = window.scrollY > 300 ? 'block' : 'none';
    });
    document.getElementById('nav-toggle')?.addEventListener('click', function() {
      document.getElementById('nav-menu')?.classList.toggle('open');
    });
  </script>
</body>
</html>
