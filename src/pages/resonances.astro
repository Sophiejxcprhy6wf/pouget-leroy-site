---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Résonances — Sophie Pouget-Leroy" description="Sources extérieures qui traversent, jazz, lecture, rencontres inattendues.">

  <div class="article-header" style="background:#d8d0c4;">
    <div class="rub-bar" style="background:#a09480; height:2px; width:28px; margin-bottom:22px;"></div>
    <p class="article-header-rub">03</p>
    <h1 class="article-header-title">Résonances</h1>
    <p class="article-header-date">Sources extérieures qui traversent, jazz, lecture, rencontres inattendues.</p>
  </div>

  <hr class="line">

  <main class="articles-zone">
    <a href="/articles/sonny-rollins" class="article-card">
      <div class="article-img img-resonances" style="padding:20px;">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#3a3835" stroke-width="1" stroke-linecap="round" stroke-linejoin="round">
          <path d="M9 18V5l12-2v13"/><circle cx="6" cy="18" r="3"/><circle cx="18" cy="16" r="3"/>
        </svg>
      </div>
      <div>
        <p class="art-rub">Mai 2026</p>
        <h2 class="art-title">Sonny Rollins et l'improvisation maîtrisée</h2>
        <p class="art-excerpt">Ce que le jazz enseigne sur l'expertise incarnée. Et pourquoi le praticien qui ne sait plus où sont ses mains joue mieux que celui qui les surveille.</p>
      </div>
    </a>
  </main>

</Layout>
